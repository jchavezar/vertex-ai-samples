GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=vtxdemos
GOOGLE_CLOUD_LOCATION=global

# Staging bucket used by Agent Engine deploys (must exist; create with `gsutil mb` if not)
DEPLOY_STAGING_BUCKET=gs://vtxdemos-agent-engine

# Filled in by scripts/deploy.py — paste the printed resource name here after first deploy
AGENT_ENGINE_RESOURCE=

# Frontend talks to this backend (CORS allowed origin)
BACKEND_PORT=8088
FRONTEND_ORIGIN=http://localhost:3000
