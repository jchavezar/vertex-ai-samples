# --- Project + region ---
# All resources are created in this project, in this region.
PROJECT=your-gcp-project
REGION=us-central1

# --- Extractor (Cloud Run + Eventarc) ---
INPUT_BUCKET=${PROJECT}-docparse-in
OUTPUT_BUCKET=${PROJECT}-docparse-out
SERVICE=docparse
SA_NAME=docparse-runner
TRIGGER_NAME=docparse-on-pdf-upload
REPO=docparse

# --- Agent (Vertex AI Agent Engine) ---
DEPLOY_PROJECT_ID=${PROJECT}
DEPLOY_LOCATION=us-central1
DEPLOY_STAGING_BUCKET=gs://${PROJECT}-staging-agent-engine
AGENT_DISPLAY_NAME=docparse RAG agent
AGENT_MODEL=gemini-3-flash-preview
AGENT_TOP_K=20

# Set after first agent deploy; deploy.sh writes it back automatically.
REASONING_ENGINE_RES=
# Set after first RAG corpus create; deploy.sh writes it back automatically.
RAG_CORPUS_NAME=

# --- Gemini Enterprise registration (optional — leave blank to skip) ---
GE_PROJECT_ID=
GE_PROJECT_NUMBER=
AS_APP=
AS_ASSISTANT=default_assistant
