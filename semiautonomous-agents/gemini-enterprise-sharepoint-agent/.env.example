# GCP Configuration
PROJECT_ID=your-project-id
PROJECT_NUMBER=123456789
LOCATION=us-central1
STAGING_BUCKET=gs://your-staging-bucket

# Discovery Engine
ENGINE_ID=your-engine-id
DATA_STORE_ID=your-datastore-id

# WIF Configuration
# NOTE: Two providers needed - one for GE login, one for agent WIF
# See docs/03-WIF-SETUP.md for details
WIF_POOL_ID=your-workforce-pool-id
WIF_PROVIDER_ID=your-agent-provider-id  # Use agent provider (with api:// client-id)

# Authorization (for Gemini Enterprise)
AUTH_ID=sharepointauth

# Microsoft Entra ID
TENANT_ID=your-tenant-id
OAUTH_CLIENT_ID=your-entra-client-id
OAUTH_CLIENT_SECRET=your-entra-client-secret  # Keep secret!

# Agentspace Configuration
AS_APP=your-agentspace-app-id

# Agent Engine (set after deployment)
# REASONING_ENGINE_RES=projects/123/locations/us-central1/reasoningEngines/456

# Agent Display
AGENT_DISPLAY_NAME=SharePoint Assistant
AGENT_DESCRIPTION=AI Assistant with access to SharePoint documents

# Required for google.adk
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
