# ── Shared GCP / Discovery Engine ─────────────────────────────────────────────
PROJECT_NUMBER=000000000000
ENGINE_ID=your-engine-id

# ── Workforce Identity Federation (WIF) ───────────────────────────────────────
WIF_POOL_ID=your-wif-pool-id
WIF_PROVIDER_ID=your-oidc-provider-id

# ── Microsoft Entra Portal App (MSAL login — same Entra tenant for both) ──────
TENANT_ID=00000000-0000-0000-0000-000000000000

# REDIRECT_URI is hardcoded to Google's oauth-redirect by Discovery Engine.
# Override only if you know what you're doing.
# REDIRECT_URI=https://vertexaisearch.cloud.google.com/oauth-redirect

# ── SharePoint connector ──────────────────────────────────────────────────────
SHAREPOINT_ENABLED=true
SHAREPOINT_CONNECTOR_ID=your-sharepoint-connector-id
SHAREPOINT_CONNECTOR_CLIENT_ID=00000000-0000-0000-0000-000000000000
SHAREPOINT_DOMAIN=contoso.sharepoint.com

# ── ServiceNow connector ──────────────────────────────────────────────────────
SERVICENOW_ENABLED=true
SERVICENOW_CONNECTOR_ID=servicenow-connector-XXXXXXXXXX
SERVICENOW_INSTANCE_URI=https://your-instance.service-now.com
SN_OAUTH_CLIENT_ID=your-servicenow-oauth-client-id
SN_OAUTH_CLIENT_SECRET=your-servicenow-oauth-client-secret
# SN_OAUTH_SCOPES=useraccount   # default — override if your SN OAuth app uses different scopes

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8003
