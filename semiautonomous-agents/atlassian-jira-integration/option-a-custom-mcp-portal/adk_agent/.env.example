# This file is the literal output of ../README.md Step 3 (the heredoc).
# Customer normally writes it via that heredoc — no copy-paste of placeholders.
# Reproduced here for reference / if you want to fill it by hand.

GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>
GOOGLE_CLOUD_QUOTA_PROJECT=<your-gcp-project-id>
GOOGLE_CLOUD_PROJECT_NUMBER=<your-gcp-project-number>
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
STAGING_BUCKET=gs://<your-gcp-project-id>-agent-staging

MCP_SERVER_URL=https://jira-mcp-server-<run-suffix>.us-central1.run.app/sse
MCP_SERVICE_RESOURCE=projects/<your-gcp-project-number>/locations/us-central1/services/jira-mcp-server

ATLASSIAN_CLIENT_ID=<from-developer.atlassian.com>
ATLASSIAN_CLIENT_SECRET=<from-developer.atlassian.com>

AGENTSPACE_AUTH_ID=atlassian-jira-oauth
