# Copy to .env (which is gitignored) and fill in real values.
# `register_datastore.py` reads .env via the same lightweight loader as
# option-a-custom-mcp-portal/register.py.

# --- Gemini Enterprise target ---
GE_PROJECT_ID=vtxdemos
GE_PROJECT_NUMBER=254356041555
GE_ENGINE_ID=jira-testing_1778158449701
GE_COLLECTION_ID=default_collection
GE_LOCATION=global

# --- The per-MCP collection / entity datastore that register_datastore.py creates.
# Filled in after the first successful run; the resulting entity datastore is
# named "<OPTION_B_DATASTORE_ID>_mcp_data" and lives in default_collection.
OPTION_B_DATASTORE_ID=jiramcp-rovo-1778188383

# --- Atlassian site you'll grant access to during the 3LO popup ---
ATLASSIAN_SITE_URL=https://sockcop.atlassian.net

# --- DCR credentials minted by dcr_register.py.
# These are written to ~/.secrets/atlassian-rovo-dcr-ge.json and read from
# there by register_datastore.py and reauth_helper.py. They are duplicated
# here for visibility but the secret file is the source of truth.
DCR_CLIENT_ID=REPLACE_ME_FROM_DCR_OUTPUT
DCR_CLIENT_SECRET=REPLACE_ME_FROM_DCR_OUTPUT
