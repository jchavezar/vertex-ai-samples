# ── GCP ────────────────────────────────────────────────────────────────────────
PROJECT_NUMBER=000000000000

# ── Discovery Engine (Gemini Enterprise) ──────────────────────────────────────
# ENGINE_ID:    your search app's engine id (Cloud Console → Agent Builder → Apps)
# CONNECTOR_ID: the SharePoint Online connector id (Cloud Console → Data Stores)
# DATA_STORE_ID: any one child data store id, e.g. "{CONNECTOR_ID}_file"
#                (only used by the auth_sharepoint.py bootstrap CLI for a smoke test)
ENGINE_ID=your-engine-id
CONNECTOR_ID=your-sharepoint-connector-id
DATA_STORE_ID=your-sharepoint-connector-id_file

# ── Workforce Identity Federation (WIF) ───────────────────────────────────────
WIF_POOL_ID=your-wif-pool-id
WIF_PROVIDER_ID=your-wif-provider-id

# ── Microsoft Entra Connector App (SharePoint OAuth consent flow) ─────────────
CONNECTOR_CLIENT_ID=00000000-0000-0000-0000-000000000000
CONNECTOR_CLIENT_SECRET=your-connector-app-client-secret
TENANT_ID=00000000-0000-0000-0000-000000000000

# REDIRECT_URI is hardcoded to Google's oauth-redirect by the connector backend.
# Override only if you know what you're doing.
# REDIRECT_URI=https://vertexaisearch.cloud.google.com/oauth-redirect

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8003
SHAREPOINT_DOMAIN=contoso.sharepoint.com

# ── Optional: auth_sharepoint.py auto-fill (Playwright bootstrap CLI only) ────
# Leave blank to type credentials manually in the popup.
# SP_USERNAME=
# SP_PASSWORD=
