# --- Where the agent runs (Agent Engine deployment) ---
DEPLOY_PROJECT_ID=your-vertex-project
DEPLOY_LOCATION=us-central1
DEPLOY_STAGING_BUCKET=gs://your-vertex-project-staging-agent-engine

# --- The RAG corpus the agent retrieves from ---
# Resource name returned by rag.create_corpus(...).name
RAG_CORPUS_NAME=projects/PROJECT_NUMBER/locations/us-central1/ragCorpora/CORPUS_ID

# --- Model + retrieval config (defaults shown) ---
AGENT_MODEL=gemini-3-flash-preview
AGENT_TOP_K=20

# --- Where the agent gets exposed (Gemini Enterprise) ---
GE_PROJECT_ID=your-ge-project
GE_PROJECT_NUMBER=000000000000
AS_APP=your_app_id_from_ge_console
AS_ASSISTANT=default_assistant

# --- Set after first deploy.py run; needed for subsequent updates ---
REASONING_ENGINE_RES=

# --- Optional cosmetic overrides for the GE registration ---
AGENT_DISPLAY_NAME=docparse RAG agent
AGENT_DESCRIPTION=
AGENT_TOOL_DESCRIPTION=
AGENT_ICON_URI=
