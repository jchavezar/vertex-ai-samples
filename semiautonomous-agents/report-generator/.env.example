# Vertex AI (per Gemini 3 preview model availability — keep on global)
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=vtxdemos
GOOGLE_CLOUD_LOCATION=global

# Models (Gemini 3 preview — see ~/.claude/.../feedback_gemini_models.md)
REPORT_PLANNER_MODEL=gemini-3-flash-preview
REPORT_RESEARCH_MODEL=gemini-3-flash-preview
REPORT_WRITER_MODEL=gemini-3-flash-preview

# Loop budget
REPORT_MAX_ITERATIONS=3

# Output
REPORT_OUTPUT_DIR=./outputs

# For Agent Engine deploys
STAGING_BUCKET=gs://vtxdemos-agent-staging
