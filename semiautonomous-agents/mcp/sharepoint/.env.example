# Microsoft 365 MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Azure AD Application (Client) ID
# Create an app registration at https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MS365_CLIENT_ID=your-app-client-id-here

# Optional: Azure AD Tenant ID
# Use 'common' for multi-tenant apps, or your specific tenant ID
MS365_TENANT_ID=common

# Optional: MCP Transport (default: streamable-http)
# Options: streamable-http, sse, stdio
MCP_TRANSPORT=streamable-http

# Optional: Server port (default: 8080)
PORT=8080
