# ============================================
# Cortex Retriever — Configuration
# ============================================

# --- GCP Project ---
PROJECT_ID=your-gcp-project-id
PROJECT_NUMBER=your-project-number
LOCATION=us-central1
STAGING_BUCKET=gs://your-staging-bucket

# --- Discovery Engine (SharePoint) ---
ENGINE_ID=your-engine-id
DATA_STORE_ID=your-sharepoint-datastore-id

# --- WIF (Token Exchange) ---
WIF_POOL_ID=your-wif-pool-id
WIF_PROVIDER_ID=your-wif-provider-id

# --- Microsoft Entra ID ---
TENANT_ID=your-entra-tenant-id
OAUTH_CLIENT_ID=your-entra-client-id
OAUTH_CLIENT_SECRET=your-client-secret

# --- Agentspace (Gemini Enterprise) ---
GE_PROJECT_ID=your-ge-project-id
GE_PROJECT_NUMBER=your-ge-project-number
AS_APP=your-agentspace-app-id
AUTH_ID=your-authorization-id

# --- Agent Engine (set after deploy.py) ---
# REASONING_ENGINE_RES=projects/.../locations/.../reasoningEngines/...

# --- Agent Display ---
AGENT_DISPLAY_NAME=Cortex Retriever
AGENT_DESCRIPTION=Search internal SharePoint documents and the public web
AGENT_ICON=https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/travel_explore/default/24px.svg
TOOL_DESCRIPTION=Use this agent to search SharePoint documents and compare with public web information

# --- ADK Runtime ---
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
