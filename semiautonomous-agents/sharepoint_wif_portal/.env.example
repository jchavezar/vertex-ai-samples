# SharePoint WIF Portal - ADK Agent Configuration
# Copy to .env and fill in your values
# Version: 1.1.0 | Date: 2026-04-05

# ========================================
# GCP Configuration
# ========================================
PROJECT_ID=your-project-id
PROJECT_NUMBER=123456789
LOCATION=us-central1
STAGING_BUCKET=gs://your-staging-bucket

# ========================================
# Discovery Engine (for SharePoint search)
# ========================================
ENGINE_ID=your-engine-id
DATA_STORE_ID=your-sharepoint-datastore-id

# ========================================
# WIF Configuration (for token exchange)
# ========================================
# Two WIF providers exist in the pool:
#   - ge-login-provider: For Gemini Enterprise login (audience: client-id only)
#   - entra-provider: For agent SharePoint WIF (audience: api://client-id)
#
# CRITICAL: Agent must use entra-provider for WIF token exchange
WIF_POOL_ID=sp-wif-pool-v2
WIF_PROVIDER_ID=entra-provider

# ========================================
# Authorization (for Gemini Enterprise)
# ========================================
# Optional: Override auto-detection of AUTH_ID from tool_context.state
# If not set, agent will pattern-match temp:* keys in state
# AUTH_ID=sharepointauth2

# ========================================
# Microsoft Entra ID
# ========================================
TENANT_ID=your-tenant-id
OAUTH_CLIENT_ID=your-entra-client-id
OAUTH_CLIENT_SECRET=your-entra-client-secret

# ========================================
# Agentspace Configuration
# ========================================
AS_APP=your-agentspace-app-id

# ========================================
# Agent Engine (set after deployment)
# ========================================
# REASONING_ENGINE_RES=projects/123/locations/us-central1/reasoningEngines/456

# ========================================
# Agent Display
# ========================================
AGENT_DISPLAY_NAME=Insight Comparator
AGENT_DESCRIPTION=AI Assistant comparing internal SharePoint docs with external web sources

# ========================================
# Required for google.adk
# ========================================
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
