PROJECT_ID=vtxdemos
LOCATION=us-central1
GEMINI_ENTERPRISE_APP_ID=your-ge-app-id_1234567890

# Filled in after running create_oauth_client.sh + console steps
OAUTH_CLIENT_ID=
