# Vertex AI (use existing GCP project)
PROJECT_ID=your-gcp-project-id
LOCATION=global

# ADK: use Vertex AI backend (not Google AI Studio)
GOOGLE_GENAI_USE_VERTEXAI=true

# Foursquare Places API v2 (FREE — 200K calls/month)
# Register at https://foursquare.com/developers → Create App → OAuth section
FOURSQUARE_CLIENT_ID=your-foursquare-client-id
FOURSQUARE_CLIENT_SECRET=your-foursquare-client-secret

# Development mode: use mock data to save API calls
# Set to "true" during development/testing
USE_MOCK_DATA=false
