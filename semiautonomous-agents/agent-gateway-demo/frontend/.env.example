# Public envs are bundled into the Next.js client build. Set BEFORE running
# `npm run build` (or pass via Cloud Run env at deploy time).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
NEXT_PUBLIC_ENTRA_TENANT_ID=
NEXT_PUBLIC_ENTRA_CLIENT_ID=
NEXT_PUBLIC_ENTRA_SCOPES=https://graph.microsoft.com/Files.Read offline_access openid profile
