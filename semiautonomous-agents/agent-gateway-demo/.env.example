# ──────────────────────────────────────────────────────────────────────────
# Google Cloud — common
# ──────────────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=vtxdemos
GOOGLE_CLOUD_PROJECT_NUMBER=254356041555
GOOGLE_CLOUD_LOCATION=global              # for the runtime model (gemini-2.5-flash)
DEPLOY_LOCATION=us-central1               # Agent Engine region (irreversible binding!)
DEPLOY_STAGING_BUCKET=gs://vtxdemos-staging

# ──────────────────────────────────────────────────────────────────────────
# Agent Engine resources (filled in after each deploy step)
# ──────────────────────────────────────────────────────────────────────────
# AGENT_ENGINE_RESOURCE=projects/254356041555/locations/us-central1/reasoningEngines/<id>
AGENT_DISPLAY_NAME=agent-gateway-demo
AGENT_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────────────────────────────────
# Agent Gateway (PERMANENT binding to vtxdemos us-central1 once provisioned)
# ──────────────────────────────────────────────────────────────────────────
GATEWAY_NAME=my-agent-gateway
# GATEWAY_RESOURCE=projects/.../locations/.../agentGateways/my-agent-gateway

# ──────────────────────────────────────────────────────────────────────────
# Agent Registry (agentregistry.googleapis.com v1alpha)
# ──────────────────────────────────────────────────────────────────────────
MCP_SERVICE_DISPLAY_NAME=sharepoint-mcp
# MCP_SERVICE_RESOURCE=projects/.../locations/.../services/<id>

# ──────────────────────────────────────────────────────────────────────────
# Auth Provider connector (3LO with Microsoft Entra)
# ──────────────────────────────────────────────────────────────────────────
CONNECTOR_NAME=sharepoint-3lo
# CONNECTOR_RESOURCE=projects/.../locations/.../connectors/sharepoint-3lo

# ──────────────────────────────────────────────────────────────────────────
# Microsoft Entra app registration  (manual — create in Entra portal first)
# Required redirect URIs:
#   https://<frontend>/auth/callback
#   http://localhost:3000/auth/callback   (for local dev)
# Required Graph permissions (delegated):  Files.Read, openid, profile, offline_access
# ──────────────────────────────────────────────────────────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_AUTHORITY=https://login.microsoftonline.com/${ENTRA_TENANT_ID}
ENTRA_AUTH_URL=https://login.microsoftonline.com/${ENTRA_TENANT_ID}/oauth2/v2.0/authorize
ENTRA_TOKEN_URL=https://login.microsoftonline.com/${ENTRA_TENANT_ID}/oauth2/v2.0/token
ENTRA_SCOPES="https://graph.microsoft.com/Files.Read offline_access openid profile"

# ──────────────────────────────────────────────────────────────────────────
# Cloud Run URLs (filled in after each `deploy.sh`)
# ──────────────────────────────────────────────────────────────────────────
# MCP_SERVER_URL=https://sharepoint-mcp-xxx.run.app
# BACKEND_URL=https://agent-gateway-demo-backend-xxx.run.app
# FRONTEND_URL=https://agent-gateway-demo-ui-xxx.run.app

# ──────────────────────────────────────────────────────────────────────────
# MCP server behaviour
# ──────────────────────────────────────────────────────────────────────────
DEMO_REAL_MCP=0           # 0 = stub mode (default), 1 = real Microsoft Graph
GRAPH_API_BASE=https://graph.microsoft.com/v1.0

# ──────────────────────────────────────────────────────────────────────────
# Agent Identity / session-state key
# (agent reads `state["temp:sharepoint_3lo"]` for the user's Entra access token)
# ──────────────────────────────────────────────────────────────────────────
SESSION_TOKEN_KEY=temp:sharepoint_3lo
