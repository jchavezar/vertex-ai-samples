# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `tester/.env` and fill in your environment values.
# `serve.py` reads .env at request time and injects these into index.html.
# Never commit a real .env — the .gitignore excludes it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Microsoft Entra (MSAL Portal App) ────────────────────────────────────────
# Same Portal App used in streamassist-oauth-flow / -us. Raw GUID, NO api:// prefix.
PORTAL_APP_CLIENT_ID=00000000-0000-0000-0000-000000000000
TENANT_ID=00000000-0000-0000-0000-000000000000

# ── GCP project + Workforce Identity Federation ──────────────────────────────
# WIF pool MUST be at locations/global/. The OIDC provider's --client-id must be
# the raw Portal App GUID (no api:// prefix) — the "raw client_id audience pattern".
PROJECT_NUMBER=000000000000
WIF_POOL_ID=your-workforce-pool-id
WIF_PROVIDER_ID=your-oidc-provider-id

# ── Discovery Engine app ─────────────────────────────────────────────────────
# Engine ID + region. The engine MUST have workforceIdentityPoolProvider set
# (Cloud Console → Apps → <engine> → Set up identity), otherwise federated
# search returns 0 results regardless of how everything else is configured.
ENGINE_ID=your-engine-id
LOCATION=global   # or "us"

# ── ServiceNow connector (created via setUpDataConnector) ────────────────────
# This is the collection ID returned by setUpDataConnector. Datastores below it
# are named <SERVICENOW_CONNECTOR_ID>_incident, _knowledge, _catalog, etc.
SERVICENOW_CONNECTOR_ID=servicenow-connector-XXXXXXXXXX

# ── ServiceNow OAuth app (Application Registry) ──────────────────────────────
# Create via: ServiceNow → System OAuth → Application Registry →
#   "Create an OAuth API endpoint for external clients".
# Redirect URL must be: https://vertexaisearch.cloud.google.com/oauth-redirect
SERVICENOW_INSTANCE_URI=https://YOUR_INSTANCE.service-now.com
SN_OAUTH_CLIENT_ID=your-servicenow-oauth-client-id
