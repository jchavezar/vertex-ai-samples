# ── GCP project ───────────────────────────────────────────────────────────────
PROJECT_NUMBER=000000000000

# ── Discovery Engine ──────────────────────────────────────────────────────────
ENGINE_ID=your-engine-id
CONNECTOR_ID=servicenow-connector-XXXXXXXXXX

# ── Workforce Identity Federation ─────────────────────────────────────────────
WIF_POOL_ID=your-wif-pool-id
WIF_PROVIDER_ID=your-oidc-provider-id

# ── Microsoft Entra (Portal App for MSAL login — same as SharePoint setup) ───
TENANT_ID=00000000-0000-0000-0000-000000000000

# ── ServiceNow OAuth app (System OAuth → Application Registry) ───────────────
SERVICENOW_INSTANCE_URI=https://your-instance.service-now.com
SN_OAUTH_CLIENT_ID=your-servicenow-oauth-client-id
SN_OAUTH_CLIENT_SECRET=your-servicenow-oauth-client-secret

# Server
BACKEND_PORT=8003
