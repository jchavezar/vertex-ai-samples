GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=vtxdemos
GOOGLE_CLOUD_LOCATION=global

# OAuth 2.0 client (Web Application type) created in vtxdemos
# Authorized redirect URI must include: http://localhost:8000/dev-ui/
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Optional: only used by agent_appint.py (the Application-Integration variant)
APPINT_PROJECT=vtxdemos
APPINT_LOCATION=us-central1
APPINT_CONNECTION=google-drive
