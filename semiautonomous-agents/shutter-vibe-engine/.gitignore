# ===========================================================
# Shutter Vibe Engine — .gitignore
# ===========================================================

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/

# Downloaded media corpus (regenerate via `python envato/pipeline.py --harvest`)
envato/assets/
data/local_cache/

# Embedding artifacts (regenerate via `python envato/pipeline.py --embed`)
envato/index/
*.npz
*.npy

# v2 segment-level caches (regenerate via `python envato/pipeline_v2.py`)
envato/segments_cache/
envato/scratch/

# Local logs / scratch / one-off benchmarks
*.log
nohup.out
server_pid.txt
bench_results.json
test_*_queries.py
bench_*.py

# Secrets / credentials — never commit
.env
.env.*
*.env
*-credentials.json
service-account*.json

# Internal-only docs (do not commit)
HANDOFF.md
demo_script.md
query_bank.md
research/
