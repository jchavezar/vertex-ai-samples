# Local-only artifacts that should never be committed.
__pycache__/
*.pyc

# Local indexing caches (regenerated by pipeline/build.py)
segments_cache/
index/
*.npz
*.npy

# Sample assets (3GB+ of media — fetched by pipeline/backfill*.py from Pexels/Pixabay)
assets/

# Astro build output
site/dist/
site/.astro/
site/node_modules/

# Logs / scratch
*.log
nohup.out
