FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY envato/deploy/requirements.ingest.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY demos/_client.py             /app/demos/_client.py
COPY envato/pipeline/build.py     /app/envato/pipeline/build.py
COPY envato/app/ingest.py         /app/envato/app/ingest.py

ENV PYTHONUNBUFFERED=1 \
    GOOGLE_GENAI_USE_VERTEXAI=True \
    GOOGLE_CLOUD_PROJECT=vtxdemos \
    GOOGLE_CLOUD_LOCATION=us-central1 \
    ENVATO_GCS_BUCKET=envato-vibe-demo \
    PORT=8080

EXPOSE 8080
WORKDIR /app/envato/app
CMD ["uvicorn", "ingest:app", "--host", "0.0.0.0", "--port", "8080"]
