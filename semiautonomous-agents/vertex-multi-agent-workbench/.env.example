# Vertex Cowork Configuration

# GCP Configuration (required)
VERTEX_COWORK_GCP_PROJECT_ID=your-project-id
VERTEX_COWORK_GCP_LOCATION=us-central1

# API Configuration
VERTEX_COWORK_API_HOST=0.0.0.0
VERTEX_COWORK_API_PORT=8080

# Database (optional - defaults to in-memory for development)
VERTEX_COWORK_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vertex_cowork
VERTEX_COWORK_REDIS_URL=redis://localhost:6379

# Framework Default
VERTEX_COWORK_DEFAULT_FRAMEWORK=adk  # or langgraph

# Model Defaults
VERTEX_COWORK_DEFAULT_MODEL=gemini-2.0-flash
VERTEX_COWORK_DEFAULT_MODEL_PROVIDER=vertex  # or model_garden

# Security
VERTEX_COWORK_ENABLE_AUTH=false

# Frontend (for Vite)
VITE_API_URL=http://localhost:8080
