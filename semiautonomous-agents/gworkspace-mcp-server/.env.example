# Google Workspace MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Google Cloud OAuth 2.0 Client ID
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Required: Google Cloud OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET=your-client-secret

# Optional: MCP Transport (default: streamable-http)
# Options: streamable-http, sse, stdio
MCP_TRANSPORT=streamable-http

# Optional: Server port (default: 8080)
PORT=8080
