# ---- Vertex AI Agent Engine (Agent Runtime) ----
GOOGLE_CLOUD_PROJECT=vtxdemos
DEPLOY_LOCATION=us-central1
DEPLOY_STAGING_BUCKET=gs://vtxdemos-staging
AGENT_ENGINE_DISPLAY_NAME=docgen-agent

# Filled in after the first successful deploy:
# AGENT_ENGINE_RESOURCE=projects/254356041555/locations/us-central1/reasoningEngines/<id>

# ---- Runtime model selection (env vars baked into the deployed Agent) ----
# `global` is required for gemini-3-* preview models. `us-central1` works for 2.x.
RUNTIME_GENAI_LOCATION=global
# NOTE: ADK 1.0 does not yet handle Gemini 3's server-side google_search return
# shape — the model emits a `function_call` for `google_search` and ADK tries
# to execute it client-side, raising "Tool 'google_search' not found.".
# Stay on 2.5-flash for now; switch to gemini-3-flash-preview once ADK ships
# the builtin grounding fix.
DOCGEN_AGENT_MODEL=gemini-2.5-flash

# ---- Gemini Enterprise registration (Discovery Engine v1alpha) ----
GE_PROJECT_ID=vtxdemos
GE_PROJECT_NUMBER=254356041555
GE_ENGINE_ID=jira-testing_1778158449701

AGENT_DISPLAY_NAME=Doc Gen
AGENT_DESCRIPTION=Researches a topic with Google Search and generates a downloadable PDF report.
TOOL_DESCRIPTION=Use this agent when the user wants a researched summary AND a downloadable PDF report. It uses Google Search for grounding and emits a PDF artifact that appears as a download chip in the chat.
AGENT_ICON=https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/picture_as_pdf/default/24px.svg
