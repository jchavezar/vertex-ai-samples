# ---- Vertex AI Agent Engine (Agent Runtime) ----
GOOGLE_CLOUD_PROJECT=vtxdemos
DEPLOY_LOCATION=us-central1
DEPLOY_STAGING_BUCKET=gs://vtxdemos-staging
AGENT_ENGINE_DISPLAY_NAME=spatial_on_ge

# Filled in after the first successful deploy:
# AGENT_ENGINE_RESOURCE=projects/254356041555/locations/us-central1/reasoningEngines/<id>

# ---- Runtime model selection (env vars baked into the deployed Agent) ----
# `global` is required for gemini-3-* preview models. `us-central1` works for 2.x.
RUNTIME_GENAI_LOCATION=global
SPATIAL_DETECTION_MODEL=gemini-2.5-flash
SPATIAL_AGENT_MODEL=gemini-2.5-flash

# ---- Gemini Enterprise registration (Discovery Engine v1alpha) ----
GE_PROJECT_ID=vtxdemos
GE_PROJECT_NUMBER=254356041555
AS_APP=agentspace-testing_1748446185255

AGENT_DISPLAY_NAME=Spatial Object Detector
AGENT_DESCRIPTION=Detects objects in attached images and renders an annotated copy with bounding boxes.
TOOL_DESCRIPTION=Use this agent to identify objects in images. The user attaches an image and asks what to detect; the agent returns the same image with coloured bounding boxes drawn around the requested objects.
AGENT_ICON=https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/frame_inspect/default/24px.svg
