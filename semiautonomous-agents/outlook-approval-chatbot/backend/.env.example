# GCP Settings
PROJECT_NUMBER=           # GCP Project Number (e.g. 545964020693)
ENGINE_ID=gemini-enterprise
CONNECTOR_ID=            # Outlook connector ID (e.g. outlook-def-connector_xxx)
WIF_POOL_ID=             # Workforce Identity Federation pool ID
WIF_PROVIDER_ID=         # WIF provider ID

# Microsoft Entra IDs
CONNECTOR_CLIENT_ID=     # Client ID of the Connector App registration
TENANT_ID=               # Directory Tenant ID

# Redirect URI (must match Connector App registration, usually this exact URI)
REDIRECT_URI=https://vertexaisearch.cloud.google.com/oauth-redirect
