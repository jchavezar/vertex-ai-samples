# Server Configuration
PORT=8001

# Google GenAI Settings
# Set to 'true' to use Vertex AI, or 'false' to use Google Developer API (requires GOOGLE_API_KEY)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=vtxdemos
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_API_KEY=

# Model to use (must be one of: gemini-2.5-flash, gemini-2.5-pro, gemini-3-flash-preview, gemini-3-pro-preview)
GEMINI_MODEL=gemini-2.5-flash

# MCP Connectors URLs (endpoints where JSON-RPC /mcp requests are sent)
JIRA_MCP_URL=https://jira-mcp-server-recipe-oyntfgdwsq-uc.a.run.app/mcp
SHAREPOINT_MCP_URL=https://ge-custom-sharepoint-mcp-oyntfgdwsq-uc.a.run.app/mcp
